            "hash": "92b0260e1b0ddae401a2c5054dd9bb54afc7f518f5b37a053fbbd17331dd73a9"
        },
        "arm64": {
            "url": "https://github.com/AnInsomniacy/motrix-next/releases/download/v3.8.9/MotrixNext_3.8.9_arm64-setup.exe#/dl.7z",
            "hash": "a1628baab7f3b3b2b7e5db07a7a5e61ff3b83e5b5a1a422b5605113c982ff2fc"
        }
    },
    "shortcuts": [
        [
            "motrix-next.exe",
            "MotrixNext"
        ]
    ],
    "persist": "binaries\\aria2.conf",
    "pre_install": [
        "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name Koolar) scripts/utils.psm1)",
        "Initialize-ExternalRuntimeData -Source \"$persist_dir\\APPDATA\" -Target \"$env:APPDATA\\com.motrix.next\"",
        "Remove-Module -Name utils"
    ],
    "post_install": [
        "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name Koolar) scripts/utils.psm1)",
        "Mount-ExternalRuntimeData -Source \"$persist_dir\\APPDATA\" -Target \"$env:APPDATA\\com.motrix.next\"",
        "Remove-Module -Name utils",
        "",
        "if (Test-Path \"$scoopdir\\apps\\aria2\\current\\aria2c.exe\") {",
        "    Rename-Item \"$dir\\motrixnext-aria2c.exe\" 'motrixnext-aria2c_exe_bac'",
        "    Copy-Item \"$scoopdir\\apps\\aria2\\current\\aria2c.exe\" \"$dir\\motrixnext-aria2c.exe\" | Out-Null",
        "}"
    ],
    "pre_uninstall": [
        "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name Koolar) scripts/utils.psm1)",
        "Stop-App",
        "Dismount-ExternalRuntimeData -Target \"$env:APPDATA\\com.motrix.next\"",
        "Remove-Module -Name utils",
        "",
        "Remove-Item \"$env:APPDATA\\com.motrix.next\" -Recurse -ErrorAction SilentlyContinue"
    ],
    "checkver": {
        "github": "https://github.com/AnInsomniacy/motrix-next"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/AnInsomniacy/motrix-next/releases/download/v$version/MotrixNext_$version_x64-setup.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://github.com/AnInsomniacy/motrix-next/releases/download/v$version/MotrixNext_$version_arm64-setup.exe#/dl.7z"
            }
        }
    }
}
