{
    "version": "3.8.10",
    "description": "A full-featured download manager — rebuilt from the ground up.",
    "homepage": "https://motrix-next.pages.dev/",
    "license": "MIT",
    "suggest": {
        "aria2": "Koolar/aria2"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/AnInsomniacy/motrix-next/releases/download/v3.8.10/MotrixNext_3.8.10_x64-setup.exe#/dl.7z",
            "hash": "c81ae0962975872b79eea46b1b2fa2ab3a8e68586c9e10efb11b5091a45cda76"
        },
        "arm64": {
            "url": "https://github.com/AnInsomniacy/motrix-next/releases/download/v3.8.10/MotrixNext_3.8.10_arm64-setup.exe#/dl.7z",
            "hash": "340dd6f4489bca736f59c7ae7e2b28c05d99935af990735e1d1806b2f503fdc2"
        }
    },
    "shortcuts": [
        [
            "motrix-next.exe",
            "MotrixNext"
        ]
    ],
    "persist": "binaries\\aria2.conf",
    "pre_install": [
        "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name Koolar) scripts/utils.psm1)",
        "Initialize-ExternalRuntimeData -Source \"$persist_dir\\LOCALAPPDATA\" -Target \"$env:LOCALAPPDATA\\com.motrix.next\"",
        "Remove-Module -Name utils"
    ],
    "post_install": [
        "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name Koolar) scripts/utils.psm1)",
        "Mount-ExternalRuntimeData -Source \"$persist_dir\\LOCALAPPDATA\" -Target \"$env:LOCALAPPDATA\\com.motrix.next\"",
        "Remove-Module -Name utils",
        "",
        "if (Test-Path \"$scoopdir\\apps\\aria2\\current\\aria2c.exe\") {",
        "    Rename-Item \"$dir\\motrixnext-aria2c.exe\" 'motrixnext-aria2c_exe_bac'",
        "    Copy-Item \"$scoopdir\\apps\\aria2\\current\\aria2c.exe\" \"$dir\\motrixnext-aria2c.exe\" | Out-Null",
        "}"
    ],
    "pre_uninstall": [
        "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name Koolar) scripts/utils.psm1)",
        "Stop-App",
        "Dismount-ExternalRuntimeData -Target \"$env:LOCALAPPDATA\\com.motrix.next\"",
        "Remove-Module -Name utils",
        "",
        "Remove-Item \"$env:APPDATA\\com.motrix.next\" -Recurse -ErrorAction SilentlyContinue"
    ],
    "checkver": {
        "github": "https://github.com/AnInsomniacy/motrix-next"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/AnInsomniacy/motrix-next/releases/download/v$version/MotrixNext_$version_x64-setup.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://github.com/AnInsomniacy/motrix-next/releases/download/v$version/MotrixNext_$version_arm64-setup.exe#/dl.7z"
            }
        }
    }
}
