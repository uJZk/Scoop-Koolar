            "Uninstall Tool"
        ]
    ],
    "pre_install": [
        "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name Koolar) scripts/utils.psm1)",
        "Initialize-ExternalRuntimeData -Source \"$env:APPDATA\\CrystalIdea Software\\Uninstall Tool\" -Target \"$persist_dir\\APPDATA\"",
        "Remove-Module -Name utils"
    ],
    "post_install": [
        "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name Koolar) scripts/utils.psm1)",
