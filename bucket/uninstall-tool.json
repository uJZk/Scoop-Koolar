        "Remove-Module -Name utils"
    ],
    "pre_uninstall": [
        "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name Koolar) scripts/utils.psm1)",
        "Stop-App",
        "Dismount-ExternalRuntimeData -Target \"$env:APPDATA\\CrystalIdea Software\\Uninstall Tool\"",
        "Remove-Module -Name utils"
    ],
    "checkver": {
        "github": "https://github.com/crystalidea/uninstall-tool"
