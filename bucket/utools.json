{
    "version": "7.8.0",
    "description": "新一代工具平台，拥有丰富的插件应用生态与 AI 生成工具，打造你的专属趁手工具箱。",
    "homepage": "https://u.tools/",
    "license": {
        "identifier": "Freeware",
        "url": "https://www.u-tools.cn/docs/agreement.html"
    },
    "architecture": {
        "64bit": {
            "url": "https://open.u-tools.cn/download/uTools-7.8.0.exe#/dl.7z",
            "hash": "1a1fea20a10dc2a691be272e4082c80e0dc7dc032e66696ab8ddf0c7a81aabe4"
        },
        "32bit": {
            "url": "https://open.u-tools.cn/download/uTools-7.8.0-ia32.exe#/dl.7z",
            "hash": "cb8644f2d8dcbf42a3fe3cab946b37cb61b1d7a4062f1bb185723881071adf00"
        }
    },
    "shortcuts": [
        [
            "uTools.exe",
            "uTools"
        ]
    ],
    "pre_install": [
        "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name Koolar) scripts/utils.psm1)",
        "Initialize-ExternalRuntimeData -Source \"$persist_dir\\APPDATA\" -Target \"$env:APPDATA\\uTools\"",
        "Remove-Module -Name utils",
        "",
        "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-$matchBitness.7z\" \"$dir\" -Removal",
        "Remove-Item \"$dir\\`$PLUGINSDIR\" -Recurse -Force -ErrorAction 'SilentlyContinue'"
    ],
    "post_install": [
        "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name Koolar) scripts/utils.psm1)",
        "Mount-ExternalRuntimeData -Source \"$persist_dir\\APPDATA\" -Target \"$env:APPDATA\\uTools\"",
        "Remove-Module -Name utils"
    ],
    "pre_uninstall": [
        "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name Koolar) scripts/utils.psm1)",
        "Dismount-ExternalRuntimeData -Target \"$env:APPDATA\\uTools\"",
        "Remove-Module -Name utils"
    ],
    "checkver": {
        "url": "https://publish.u-tools.cn/release/latest.yml",
        "regex": "version:\\s*([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://open.u-tools.cn/download/uTools-$version.exe#/dl.7z"
            },
            "32bit": {
                "url": "https://open.u-tools.cn/download/uTools-$version-ia32.exe#/dl.7z"
            }
        }
    }
}
