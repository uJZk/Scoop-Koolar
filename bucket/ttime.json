    },
    "shortcuts": [
        [
            "TTime.exe",
            "TTime"
        ]
    ],
    "pre_install": [
        "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name Koolar) scripts/utils.psm1)",
        "Initialize-ExternalRuntimeData -Source \"$env:APPDATA\\time-translate\\userDataConfig\" -Target \"$persist_dir\\APPDATA\"",
        "Remove-Module -Name utils",
        "",
        "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\" -Removal",
        "Remove-Item \"$dir\\`$PLUGINSDIR\" -Recurse -Force -ErrorAction 'SilentlyContinue'"
    ],
    "post_install": [
        "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name Koolar) scripts/utils.psm1)",
        "Mount-ExternalRuntimeData -Source \"$persist_dir\\APPDATA\" -Target \"$env:APPDATA\\time-translate\\userDataConfig\"",
        "Remove-Module -Name utils"
    ],
    "pre_uninstall": [
        "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name Koolar) scripts/utils.psm1)",
        "Dismount-ExternalRuntimeData -Target \"$env:APPDATA\\time-translate\\userDataConfig\"",
        "Remove-Module -Name utils"
    ],
    "checkver": {
        "url": "https://github.com/InkTimeRecord/TTime/releases.atom",
        "regex": "<title>[vV]?(\\S+)</title>"
    },
    "autoupdate": {
        "architecture": {
