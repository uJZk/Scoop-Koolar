{
    "version": "2.3.0",
    "description": "ProxiFyre is a Windows SOCKS5 proxifier that leverages NDISAPI to transparently route TCP and UDP traffic on a per-application basis.",
    "homepage": "https://github.com/wiresock/proxifyre",
    "license": "AGPL-3.0",
    "depends": "Koolar/winsw",
    "architecture": {
        "64bit": {
            "url": "https://github.com/wiresock/proxifyre/releases/download/v2.3.0/ProxiFyre-v2.3.0-x64-signed.zip",
            "hash": "278af809d83a85ffd84f1d51b309fa504bfde309f22f38ae9b20bf81be9c8f1e"
        },
        "32bit": {
            "url": "https://github.com/wiresock/proxifyre/releases/download/v2.3.0/ProxiFyre-v2.3.0-x86-signed.zip",
            "hash": "7a5dc33b8041439c92effd02182eac4d9a9cedc41c60a833626a68999d044a67"
        },
        "arm64": {
            "url": "https://github.com/wiresock/proxifyre/releases/download/v2.3.0/ProxiFyre-v2.3.0-ARM64-signed.zip",
            "hash": "cb9ff25091d59433337423224d3824b37d0eb4172ce08cc1df8b0e2a3d2adf28"
        }
    },
    "persist": [
        "app-config.json",
        "ProxiFyre.xml"
    ],
    "notes": [
        "ProxiFyre is installed as a Windows service through WinSW.",
        "ProxiFyre requires Windows Packet Filter (WinpkFilter) driver to be installed on your system. You can download it from https://github.com/wiresock/ndisapi/releases."
    ],
    "pre_install": [
        "if(-not (Test-Path \"$dir/app-config.json\")) { Add-Content \"$dir/app-config.json\" $null }",
        "if(-not (Test-Path \"$dir/ProxiFyre.xml\")) {",
        "    Set-Content -Path \"$dir/ProxiFyre.xml\" -Encoding UTF8 -Value @'",
        "<service>",
        "    <id>proxifyre</id>",
        "    <name>ProxiFyre</name>",
        "    <description>ProxiFyre is a Windows SOCKS5 proxifier that leverages NDISAPI to transparently route TCP and UDP traffic on a per-application basis.</description>",
        "    <executable>%BASE%\\ProxiFyre.exe</executable>",
        "    <log mode=\"reset\"></log>",
        "    <priority>abovenormal</priority>",
        "</service>",
        "'@",
        "}"
    ],
    "post_install": [
        "$winswConfig = \"$dir\\ProxiFyre.xml\"",
        "$postInstallScript = \"$dir\\_post_install.ps1\"",
        "Set-Content -Path $postInstallScript -Value @\"",
        "`$service = Get-Service -Name ProxiFyre -ErrorAction SilentlyContinue",
        "if (`$null -eq `$service) {",
        "   Write-Host 'Service not found, installing ProxiFyre as a service...' -ForegroundColor Yellow",
        "    winsw install '$winswConfig'",
        "} else {",
        "    Write-Host 'Service already exists, refreshing...' -ForegroundColor Yellow",
        "    winsw refresh '$winswConfig'",
        "}",
        "Write-Host 'Creating firewall exception...' -ForegroundColor Yellow",
        "Remove-NetFirewallRule -DisplayName ProxiFyre -ErrorAction SilentlyContinue",
        "New-NetFirewallRule -DisplayName ProxiFyre -Direction Inbound -Program '$original_dir\\ProxiFyre.exe' -Protocol TCP -Action Allow",
        "New-NetFirewallRule -DisplayName ProxiFyre -Direction Inbound -Program '$original_dir\\ProxiFyre.exe' -Protocol UDP -Action Allow",
        "\"@",
        "Write-Host",
        "sudo powershell -NoProfile -ExecutionPolicy Bypass -File \"$postInstallScript\"",
        "Remove-Item \"$postInstallScript\" -ErrorAction SilentlyContinue",
        "Write-Host \"List of useful commands:\" -ForegroundColor Blue",
        "Write-Host \"winsw status '$winswConfig'\" -ForegroundColor Blue",
        "Write-Host \"winsw refresh '$winswConfig'\" -ForegroundColor Blue",
        "Write-Host \"winsw start '$winswConfig'\" -ForegroundColor Blue",
        "Write-Host \"winsw stop '$winswConfig'\" -ForegroundColor Blue",
        "Write-Host \"winsw restart '$winswConfig'\" -ForegroundColor Blue"
    ],
    "pre_uninstall": [
        "$preUninstallScript = \"$dir\\_pre_uninstall.ps1\"",
        "Set-Content -Path $preUninstallScript -Value @\"",
        "`$service = Get-Service -Name ProxiFyre -ErrorAction SilentlyContinue",
        "if (`$null -ne `$service) {",
        "    Write-Host 'Stopping and uninstalling ProxiFyre service...' -ForegroundColor Yellow",
        "    winsw stop '$dir\\ProxiFyre.xml'",
        "    winsw uninstall '$dir\\ProxiFyre.xml'",
        "}",
        "Write-Host 'Removing firewall exception...' -ForegroundColor Yellow",
        "Remove-NetFirewallRule -DisplayName ProxiFyre -ErrorAction SilentlyContinue",
        "\"@",
        "Write-Host",
        "sudo powershell -NoProfile -ExecutionPolicy Bypass -File \"$preUninstallScript\"",
        "Remove-Item \"$preUninstallScript\" -ErrorAction SilentlyContinue"
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/wiresock/proxifyre/releases/download/v$version/ProxiFyre-v$version-x64-signed.zip"
            },
            "32bit": {
                "url": "https://github.com/wiresock/proxifyre/releases/download/v$version/ProxiFyre-v$version-x86-signed.zip"
            },
            "arm64": {
                "url": "https://github.com/wiresock/proxifyre/releases/download/v$version/ProxiFyre-v$version-ARM64-signed.zip"
            }
        }
    }
}
